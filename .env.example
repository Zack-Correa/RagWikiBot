# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_bot_client_id_here
BOT_USER_ID=your_bot_user_id_here
GUILD_ID=your_guild_id_here

# Divine Pride API
DIVINE_PRIDE_API_KEY=your_divine_pride_api_key_here

# Logging
LOG_LEVEL=INFO

# Admin Panel Configuration
ADMIN_PASSWORD=your_secure_admin_password_here
ADMIN_PORT=3000
ADMIN_HOST=0.0.0.0
SESSION_SECRET=your_session_secret_here

# Server Status Notifications (Optional)
# Discord channel ID to receive online/offline alerts
STATUS_CHANNEL_ID=

# Player Count Monitoring (Optional)
# Your GNJoy LATAM login email (required for SSO strategy)
RO_PROBE_USERNAME=your_email@example.com

# SSO Token (captured automatically by the token-capture plugin)
# Enable the plugin: /plugin enable token-capture
# Start the proxy: /token-capture start
# Log into the game normally — the token is saved here automatically
# See TOKEN_CAPTURE.md for full setup instructions
RO_AUTH_TOKEN=

# Changelog Monitor (Optional)
# Discord channel ID to receive automatic changelog summaries
CHANGELOG_CHANNEL_ID=

# LLM Service (Optional - for natural language changelog summaries)
# Provider: gemini (free), groq (free+fast), ollama (local), openai, or custom
# Gemini: free tier - 15 RPM, 1000 req/dia - get key at https://aistudio.google.com/apikey
LLM_PROVIDER=
# API key (required for gemini/groq/openai, not needed for ollama)
LLM_API_KEY=
# Model override (defaults: gemini=gemini-2.5-flash, groq=llama-3.3-70b-versatile, ollama=gemma3:4b, openai=gpt-4o-mini)
LLM_MODEL=
# Custom base URL (optional, auto-detected from provider)
LLM_BASE_URL=
# Max tokens for generation (default: 2048)
LLM_MAX_TOKENS=
# Temperature 0.0-1.0 (default: 0.7)
LLM_TEMPERATURE=

# Salesforce Agentforce (Optional - for AI assistant plugin)
SALESFORCE_CLIENT_ID=your_salesforce_client_id
SALESFORCE_CLIENT_SECRET=your_salesforce_client_secret
SALESFORCE_INSTANCE_URL=https://your-instance.my.salesforce.com
AGENTFORCE_AGENT_ID=your_agentforce_agent_id
